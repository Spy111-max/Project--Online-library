# ─────────────────────────────────────────────────────────────
# Virtual Library — Backend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# CORS — the URL of your Vite frontend
FRONTEND_URL=http://localhost:5174

# ── Email (SMTP) ─────────────────────────────────────────────
# Gmail: use an App Password (not your real Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
# Make sure "2-Step Verification" is ON first.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false          # true for port 465, false for 587 (STARTTLS)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM="Cozy Library 📚 <your_gmail@gmail.com>"

# ── JWT Secrets ───────────────────────────────────────────────
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_RESET_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_RESET_EXPIRES_IN=15m
